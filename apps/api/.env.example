DATABASE_URL=postgresql://moodle:moodle@localhost:5432/moodlenext
JWT_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:3000
PORT=4000

# Legacy Moodle database (read-only Anticorruption Layer)
# Expose MariaDB port in docker-compose: "3307:3306"
LEGACY_DB_HOST=localhost
LEGACY_DB_PORT=3307
LEGACY_DB_USER=moodle
LEGACY_DB_PASSWORD=moodlepassword
LEGACY_DB_NAME=moodle

# Strangler Fig migration flags
# Set to "true" when a module's behavioral tests pass in the new system
MIGRATED_COURSE=false
MIGRATED_ENROLLMENT=false
MIGRATED_GRADING=false
MIGRATED_IDENTITY=false
MIGRATED_ACTIVITY=false
