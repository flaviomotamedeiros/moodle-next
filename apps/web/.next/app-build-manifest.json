      "static/chunks/main-app.js",
      "static/chunks/app/(app)/explore/page.js"
    ],
    "/(app)/dashboard/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/dashboard/page.js"
    ],
    "/(app)/grades/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/grades/page.js"
    ]
  }
